{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix app install && npm --prefix app run build",
  "installCommand": "npm --prefix app install",
  "outputDirectory": "app/dist",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
